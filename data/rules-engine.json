  "infrastructureRules": {
    "description": "Auto-calculated backbone equipment based on total device counts",
    "amplifiers": {
      "symbolId": "AV-AMP-01",
      "formula": "ceil(totalSpeakers / 16)",
      "description": "1 amp per 16 speakers (4 channels × 4 speakers)"
    },
    "dsp": {
      "symbolId": "AV-DSP-01",
      "formula": "ceil(totalZones / 12)",
      "description": "1 DSP per 12 audio zones"
    },
    "switches": {
      "symbolId": "NET-SW-48",
      "formula": "ceil(totalPoeDevices / 40)",
      "description": "1 switch per 40 PoE devices (reserve 8 ports)",
      "fallback": {
        "symbolId": "NET-SW-24",
        "condition": "totalPoeDevices <= 20",
        "description": "Use 24-port if under 20 devices"
      }
    },
    "firewall": {
      "symbolId": "NET-FW-01",
      "formula": "1",
      "description": "1 per property"
    },
    "nvr": {
      "symbolId": "AC-NVR-01",
      "formula": "ceil(totalCameras / 16)",
      "description": "1 NVR per 16 cameras"
    },
    "accessPanels": {
      "symbolId": "AC-PANEL-01",
      "formula": "ceil(totalReaders / 8)",
      "description": "1 panel per 8 card readers"
    }
  }
